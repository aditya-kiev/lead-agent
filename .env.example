APP_NAME=Lead Qualification Agent
DEBUG=false

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lead_agent
REDIS_URL=redis://localhost:6379/0

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.1

LANGCHAIN_TRACING_V2=false
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=lead-qualification-agent

VERTICAL=generic                # generic | real_estate | insurance
BUSINESS_NAME=Your Business Name  # Used in all lead-facing prompts
QUALIFICATION_THRESHOLD_HOT=0.7
QUALIFICATION_THRESHOLD_WARM=0.4
HUMAN_HANDOFF_CONFIDENCE=0.3

# Demo token signing secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
DEMO_TOKEN_SECRET=change-me-to-a-random-64-char-string
